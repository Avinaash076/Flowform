# Block direct access to app folder
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /flowform/app/
    
    # Block all direct access
    RewriteRule ^(.*)$ - [F,L]
</IfModule>

# Disable PHP execution
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Additional security
Options -Indexes
